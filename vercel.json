{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/blog/(.*)", "dest": "/blog/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
